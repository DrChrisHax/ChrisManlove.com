---
import projectsData from '../data/projects.json';
import skillsData from '../data/skills.json';
import experienceData from '../data/experience.json';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Chris Manlove | High-Performance C++ Systems Engineer",
  description = "Chris Manlove is a computer systems engineer who builds high-performance software in C++20.",
} = Astro.props;

const path = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <slot name="head" />

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background-color: #000;
        color: #fff;
        font-family: system-ui, -apple-system, sans-serif;
        line-height: 1.6;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
    </style>

    <style is:global>
      /* ── Header / Nav ─────────────────────────────────────────────────── */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: #000;
        border-bottom: 1px solid #1a1a1a;
        padding: 0 1.5rem;
      }

      .site-header nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 800px;
        margin: 0 auto;
        height: 3.5rem;
      }

      .nav-brand {
        font-weight: 700;
        font-size: 1rem;
        color: #fff;
        text-decoration: none;
        letter-spacing: -0.3px;
        flex-shrink: 0;
      }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 1.75rem;
      }

      .nav-links {
        display: flex;
        gap: 1.75rem;
        list-style: none;
      }

      .nav-links a {
        color: #666;
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.15s;
      }

      .nav-links a:hover,
      .nav-links a[aria-current="page"] {
        color: #fff;
      }

      /* ── Nav auth area ────────────────────────────────────────────────── */
      .nav-auth { position: relative; display: flex; align-items: center; }

      .nav-auth-login {
        appearance: none;
        -webkit-appearance: none;
        background: #000;
        border: none;
        border-radius: 6px;
        color: #22c55e;
        font-size: 0.8rem;
        font-family: inherit;
        padding: 0.35rem 0.8rem;
        cursor: pointer;
        transition: color 0.15s, background 0.15s, box-shadow 0.15s;
        letter-spacing: 0.01em;
      }
      .nav-auth-login:hover {
        color: #4ade80;
        background: #111;
        box-shadow: 0 0 0 3px rgba(139,92,246,0.25);
      }

      .nav-avatar-wrap { position: relative; }

      .nav-avatar-btn {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid #2a2a2a;
        background: #111;
        cursor: pointer;
        padding: 0;
        display: block;
        flex-shrink: 0;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .nav-avatar-btn:hover {
        border-color: #22c55e;
        box-shadow: 0 0 0 3px rgba(34,197,94,0.15);
      }

      .nav-avatar-img {
        width: 34px;
        height: 34px;
        object-fit: cover;
        display: block;
        border-radius: 50%;
      }

      .nav-avatar-letter {
        font-size: 0.85rem;
        font-weight: 700;
        color: #22c55e;
        line-height: 1;
        user-select: none;
      }

      .nav-dropdown {
        position: absolute;
        right: 0;
        top: calc(100% + 0.6rem);
        background: #000;
        border: none;
        border-radius: 8px;
        min-width: 140px;
        z-index: 200;
        overflow: hidden;
        box-shadow: 0 12px 40px rgba(0,0,0,0.6);
      }

      .nav-dropdown-item,
      .nav-dropdown-item:link,
      .nav-dropdown-item:visited {
        display: block;
        width: 100%;
        padding: 0.65rem 1rem;
        font-size: 0.85rem;
        color: #22c55e;
        text-decoration: none;
        background: none;
        border: none;
        text-align: left;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        font-family: inherit;
        box-sizing: border-box;
      }
      .nav-dropdown-item:hover { background: rgba(139,92,246,0.15); color: #4ade80; }

      /* ── Login modal ──────────────────────────────────────────────────── */
      .auth-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.75);
        z-index: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        backdrop-filter: blur(2px);
      }
      .auth-modal-overlay[hidden] { display: none; }

      .auth-modal-card {
        background: #111;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 2rem;
        max-width: 360px;
        width: 100%;
        position: relative;
        text-align: center;
      }

      .auth-modal-close {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        background: none;
        border: none;
        color: #6b7280;
        font-size: 1.1rem;
        cursor: pointer;
        line-height: 1;
        padding: 0.25rem;
      }
      .auth-modal-close:hover { color: #fff; }

      .auth-modal-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #f9fafb;
        margin-bottom: 0.4rem;
      }

      .auth-modal-sub {
        font-size: 0.85rem;
        color: #6b7280;
        margin-bottom: 1.5rem;
        line-height: 1.5;
      }

      .auth-google-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.6rem 1.25rem;
        background: #fff;
        color: #111;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        border-radius: 6px;
        transition: background 0.15s;
      }
      .auth-google-btn:hover { background: #e5e7eb; }

      /* ── Main ─────────────────────────────────────────────────────────── */
      main {
        flex: 1;
        padding: 3rem 1.5rem;
        max-width: 800px;
        width: 100%;
        margin: 0 auto;
      }

      /* ── Footer ───────────────────────────────────────────────────────── */
      footer {
        border-top: 1px solid #1a1a1a;
        padding: 2rem 1.5rem;
      }

      .footer-inner {
        max-width: 800px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }

      .footer-name { font-weight: 600; font-size: 0.875rem; color: #fff; }

      .footer-links { display: flex; gap: 1.5rem; flex-wrap: wrap; }

      .footer-links a {
        color: #666;
        text-decoration: none;
        font-size: 0.8rem;
        transition: color 0.15s;
      }
      .footer-links a:hover { color: #fff; }

      .footer-copy { font-size: 0.72rem; color: #333; margin-top: 0.25rem; }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="nav-brand">Chris Manlove</a>
        <div class="nav-right">
          <ul class="nav-links">
            <li>
              <a href="/" aria-current={path === "/" ? "page" : undefined}>Home</a>
            </li>
            <li>
              <a href="/blog" aria-current={path.startsWith("/blog") ? "page" : undefined}>Blog</a>
            </li>
          </ul>
          <div class="nav-auth" id="nav-auth"></div>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <div class="footer-name">Chris Manlove</div>
        <div class="footer-links">
          <a href="mailto:cmanlove1234@outlook.com">cmanlove1234@outlook.com</a>
          <a href="https://www.linkedin.com/in/chris-manlove-b26b31209/" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://github.com/DrChrisHax" rel="noopener noreferrer">GitHub</a>
          <a href="https://x.com/DrChrisHax" rel="noopener noreferrer">X</a>
          <a href="https://www.youtube.com/@DrChrisHax" rel="noopener noreferrer">YouTube</a>
        </div>
        <div class="footer-copy">&copy; 2026 Chris Manlove</div>
      </div>
    </footer>

    <!-- Login modal (shared across all pages) -->
    <div id="auth-modal" class="auth-modal-overlay" hidden>
      <div class="auth-modal-card">
        <button class="auth-modal-close" id="auth-modal-close" aria-label="Close">✕</button>
        <p class="auth-modal-title">Sign in to comment</p>
        <p class="auth-modal-sub">Use your Google account to join the conversation.</p>
        <a id="auth-modal-btn" href="/api/auth/login" class="auth-google-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Continue with Google
        </a>
      </div>
    </div>

    <script define:vars={{ projectsData, skillsData, experienceData }}>
      // ── MCP context ──────────────────────────────────────────────────────
      if ('modelContext' in navigator) {
        navigator.modelContext.provideContext({
          tools: [
            {
              name: 'get_about',
              description: 'Returns professional summary and contact information for Chris Manlove, a high-performance C++ systems engineer.',
              inputSchema: { type: 'object', properties: {} },
              execute: async () => ({
                name: 'Chris Manlove',
                title: 'High-Performance C++ Systems Engineer',
                specializations: ['Low-level computing efficiency', 'Systems programming', 'High-throughput network design'],
                email: 'cmanlove1234@outlook.com',
                github: 'https://github.com/DrChrisHax',
                linkedin: 'https://www.linkedin.com/in/chris-manlove-b26b31209/',
                x: 'https://x.com/DrChrisHax',
              }),
            },
            {
              name: 'list_projects',
              description: 'Returns all portfolio projects with names, tech stacks, GitHub URLs, and descriptions.',
              inputSchema: { type: 'object', properties: {} },
              execute: async () => projectsData,
            },
            {
              name: 'get_skills',
              description: 'Returns technical skills grouped by category (Languages, Systems Programming, Computer Science, Domain Knowledge, Tools).',
              inputSchema: { type: 'object', properties: {} },
              execute: async () => skillsData,
            },
            {
              name: 'list_experience',
              description: 'Returns professional work experience and internships in reverse chronological order.',
              inputSchema: { type: 'object', properties: {} },
              execute: async () => experienceData,
            },
          ],
        });
      }

      // ── Shared auth promise (one fetch per page, reused by comment section) ──
      window.__authPromise = fetch('/api/auth/me')
        .then(r => r.ok ? r.json() : null)
        .catch(() => null);

      // ── Login modal ──────────────────────────────────────────────────────
      const authModal   = document.getElementById('auth-modal');
      const authModalBtn = document.getElementById('auth-modal-btn');
      const authModalClose = document.getElementById('auth-modal-close');

      window.showLoginModal = function () {
        authModalBtn.href = '/api/auth/login?return=' + encodeURIComponent(window.location.pathname);
        authModal.hidden = false;
        document.body.style.overflow = 'hidden';
      };

      function closeAuthModal() {
        authModal.hidden = true;
        document.body.style.overflow = '';
      }

      authModalClose.onclick = closeAuthModal;
      authModal.addEventListener('click', e => { if (e.target === authModal) closeAuthModal(); });
      document.addEventListener('keydown', e => { if (e.key === 'Escape' && !authModal.hidden) closeAuthModal(); });

      // ── Nav auth ─────────────────────────────────────────────────────────
      window.__authPromise.then(user => {
        const container = document.getElementById('nav-auth');
        if (!container) return;

        if (!user) {
          const btn = document.createElement('button');
          btn.className = 'nav-auth-login';
          btn.textContent = 'Sign in';
          btn.onclick = window.showLoginModal;
          container.appendChild(btn);
          return;
        }

        const wrap = document.createElement('div');
        wrap.className = 'nav-avatar-wrap';

        // Avatar button
        const avatarBtn = document.createElement('button');
        avatarBtn.className = 'nav-avatar-btn';
        avatarBtn.setAttribute('aria-label', 'Account menu');
        avatarBtn.setAttribute('aria-haspopup', 'true');

        const setLetterAvatar = () => {
          avatarBtn.innerHTML = '';
          const letter = document.createElement('span');
          letter.className = 'nav-avatar-letter';
          letter.textContent = (user.displayName || user.email || '?')[0].toUpperCase();
          avatarBtn.appendChild(letter);
        };

        if (user.picture) {
          const img = document.createElement('img');
          img.src = user.picture;
          img.alt = user.displayName || 'Profile photo';
          img.className = 'nav-avatar-img';
          img.onerror = setLetterAvatar;
          avatarBtn.appendChild(img);
        } else {
          setLetterAvatar();
        }

        // Dropdown
        const dropdown = document.createElement('div');
        dropdown.className = 'nav-dropdown';
        dropdown.hidden = true;

        // Sign out
        const signOut = Object.assign(document.createElement('a'), {
          className: 'nav-dropdown-item',
          href: '/api/auth/logout',
          textContent: 'Sign out',
        });
        dropdown.appendChild(signOut);

        wrap.appendChild(avatarBtn);
        wrap.appendChild(dropdown);
        container.appendChild(wrap);

        avatarBtn.onclick = e => {
          e.stopPropagation();
          dropdown.hidden = !dropdown.hidden;
        };
        document.addEventListener('click', () => { dropdown.hidden = true; });
        dropdown.addEventListener('click', e => e.stopPropagation());
      });
    </script>
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "04f4e714027643808b3544e4a824afa2"}'></script>
  </body>
</html>

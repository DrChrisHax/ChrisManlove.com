---
import BaseLayout from "../layouts/BaseLayout.astro";
import overview from "../data/overview.json";
import education from "../data/education.json";
import experience from "../data/experience.json";
import projects from "../data/projects.json";
import skills from "../data/skills.json";
import achievements from "../data/achievements.json";

const title = "Chris Manlove | High-Performance C++ Systems Engineer";
const description =
  "Chris Manlove is a high-performance C++ systems engineer specializing in low-level computing efficiency, systems programming, and high-throughput network design.";
const url = "https://chrismanlove.com";

function dateRange(start: string, end: string | null): string {
  if (!end) return `${start} - Present`;
  if (start === end) return start;
  return `${start} - ${end}`;
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Chris Manlove",
  alternateName: ["Christopher Manlove", "DrChrisHax", "Christopher Charles Manlove"],
  url,
  email: "cmanlove1234@outlook.com",
  jobTitle: "High-Performance C++ Systems Engineer",
  description,
  alumniOf: [
    {
      "@type": "CollegeOrUniversity",
      name: "California State University, Fullerton",
      address: { "@type": "PostalAddress", addressLocality: "Fullerton", addressRegion: "CA" },
    },
    {
      "@type": "CollegeOrUniversity",
      name: "Orange Coast College",
      address: { "@type": "PostalAddress", addressLocality: "Costa Mesa", addressRegion: "CA" },
    },
  ],
  knowsAbout: [
    "C++", "C++20", "C++23",
    "Software Engineering", "Data Structures", "Algorithms",
    "Computer Architecture", "Operating Systems",
    "Computer Networking", "Network Programming",
    "Object-Oriented Programming", "Computer Science", "Compilers",
    "Backend Engineering", "Low Latency", "Concurrency", "Multithreading",
    "Lock-Free Programming", "Cache Lines", "Memory Management", "NUMA",
    "Performance Optimization", "Cryptography",
    "Quant", "High Frequency Trading", "Kernel Bypass",
  ],
  sameAs: [
    "https://www.linkedin.com/in/chris-manlove-b26b31209/",
    "https://github.com/DrChrisHax",
  ],
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <meta name="author" content="Chris Manlove" />
    <meta name="keywords" content="Chris Manlove, Christopher Manlove, C++, C++20, C++23, Software Engineer, Data Structures, Algorithms, Computer Architecture, Operating Systems, Computer Networking, Network Programming, Object-Oriented Programming, Computer Science, Compilers, Backend Engineering, Low Latency, Concurrency, Multithreading, Lock-Free Programming, Cache Lines, Memory Management, NUMA, Performance Optimization, Cryptography, Quant, High Frequency Trading, Kernel Bypass" />
    <meta name="google-site-verification" content="tpjh_vr_KbK4cKP3c1Ix4_TYxXtyOdMgOcaB_fVCgW4" />
    <link rel="canonical" href={url} />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Chris Manlove" />
    <meta property="profile:first_name" content="Chris" />
    <meta property="profile:last_name" content="Manlove" />
    <meta property="profile:username" content="DrChrisHax" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- Overview -->
  <section id="overview" aria-label="Overview">
    <h1>{overview.name}</h1>
    <p class="role-title">{overview.roleTitle}</p>
    <p class="location">{overview.location}</p>
    <p class="intro">{overview.intro}</p>
  </section>

  <!-- Education -->
  <section id="education" aria-label="Education">
    <h2 class="section-title">Education</h2>
    {education.map((edu) => (
      <article class="card">
        <div class={`card-logo logo-${edu.logoStyle}`}>{edu.logoText}</div>
        <div class="card-body">
          <div class="card-header">
            <div class="card-title-group">
              <h3>{edu.school}</h3>
              <p class="subtitle-text">
                {edu.degree}{edu.minor ? `, Minor in ${edu.minor}` : ""}
              </p>
              <p class="meta-text">
                {edu.location}{edu.gpa ? ` · GPA ${edu.gpa}` : ""}
              </p>
            </div>
            <time class="date-badge">{dateRange(edu.start, edu.end)}</time>
          </div>
          <div class="tag-list">
            {edu.coursework.map((course) => (
              <span class="tag">{course}</span>
            ))}
          </div>
        </div>
      </article>
    ))}
  </section>

  <!-- Experience -->
  <section id="experience" aria-label="Experience">
    <h2 class="section-title">Experience</h2>
    {experience.map((job) => (
      <article class="card">
        <div class={`card-logo logo-${job.logoStyle}`}>{job.logoText}</div>
        <div class="card-body">
          <div class="card-header">
            <div class="card-title-group">
              <h3>{job.role}</h3>
              <p class="subtitle-text">{job.company} · {job.location}</p>
            </div>
            <time class="date-badge">{dateRange(job.start, job.end)}</time>
          </div>
          <ul class="bullet-list">
            {job.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </div>
      </article>
    ))}
  </section>

  <!-- Projects -->
  <section id="projects" aria-label="Projects">
    <h2 class="section-title">Projects</h2>
    {projects.map((proj) => (
      <article class="card">
        <div class="card-body">
          <div class="card-header">
            <div class="card-title-group">
              <h3 class="proj-title">
                <a href={proj.url} rel="noopener noreferrer">{proj.name}</a>
              </h3>
              <div class="tech-list">
                {proj.tech.map((t) => (
                  <span class="tech">{t}</span>
                ))}
              </div>
            </div>
            <time class="date-badge">{dateRange(proj.start, proj.end)}</time>
          </div>
          <ul class="bullet-list">
            {proj.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </div>
      </article>
    ))}
  </section>

  <!-- Skills -->
  <section id="skills" aria-label="Skills">
    <h2 class="section-title">Skills</h2>
    {skills.map((group) => (
      <div class="skill-group">
        <h3 class="skill-category">{group.category}</h3>
        <div class="skill-list">
          {group.items.map((item) => (
            <span class="skill">{item}</span>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- Achievements -->
  <section id="achievements" aria-label="Awards and Achievements">
    <h2 class="section-title">Awards and Achievements</h2>
    {achievements.map((ach) => (
      <div class="ach-row">
        <div class="ach-info">
          <span class="ach-name">{ach.name}</span>
          {ach.issuer && <span class="ach-issuer">{ach.issuer}</span>}
        </div>
        {ach.date && <time class="date-badge">{ach.date}</time>}
      </div>
    ))}
  </section>
</BaseLayout>

<style>
  /* Overview */
  h1 {
    font-size: 2.75rem;
    font-weight: 700;
    letter-spacing: -1px;
    margin-bottom: 0.2rem;
  }

  .role-title {
    font-size: 1.05rem;
    color: #22c55e;
    font-weight: 500;
    margin-bottom: 0.2rem;
  }

  .location {
    font-size: 0.85rem;
    color: #6b7280;
    margin-bottom: 1.25rem;
  }

  .intro {
    font-size: 0.975rem;
    color: #d1d5db;
    line-height: 1.75;
    max-width: 620px;
  }

  /* Sections */
  section { margin-bottom: 4rem; }
  #overview { margin-bottom: 3rem; }

  .section-title {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: #22c55e;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid #1a1a1a;
    margin-bottom: 1.25rem;
  }

  /* Cards */
  .card {
    background: #0a0a0a;
    border: 1px solid #1e1e1e;
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 0.85rem;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    transition: border-color 0.15s;
  }

  .card:hover { border-color: #2d2d2d; }

  .card-logo {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.5px;
    flex-shrink: 0;
  }

  .logo-csuf  { background: #052e16; color: #4ade80; border: 1px solid #14532d; }
  .logo-occ   { background: #042f2e; color: #5eead4; border: 1px solid #134e4a; }
  .logo-scalp { background: #1e1b4b; color: #c084fc; border: 1px solid #312e81; }
  .logo-jw    { background: #2d1b69; color: #a78bfa; border: 1px solid #4c1d95; }

  .card-body { flex: 1; min-width: 0; }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.6rem;
  }

  .card-title-group h3 {
    font-size: 1rem;
    font-weight: 600;
    color: #f9fafb;
    margin-bottom: 0.15rem;
  }

  .subtitle-text {
    font-size: 0.85rem;
    color: #9ca3af;
    margin-bottom: 0.1rem;
  }

  .meta-text {
    font-size: 0.78rem;
    color: #6b7280;
  }

  /* Date badges (purple) */
  .date-badge {
    font-size: 0.72rem;
    color: #c084fc;
    background: #1a0930;
    border: 1px solid #6b21a8;
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Coursework tags */
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.65rem;
  }

  .tag {
    font-size: 0.72rem;
    background: #042214;
    border: 1px solid #15803d;
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
    color: #4ade80;
  }

  /* Bullet lists */
  .bullet-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-top: 0.5rem;
  }

  .bullet-list li {
    font-size: 0.875rem;
    color: #d1d5db;
    padding-left: 1rem;
    position: relative;
    line-height: 1.5;
  }

  .bullet-list li::before {
    content: '-';
    position: absolute;
    left: 0;
    color: #22c55e;
    font-weight: 600;
  }

  /* Projects */
  .proj-title { margin-bottom: 0.3rem; }

  .proj-title a {
    color: #f9fafb;
    text-decoration: none;
  }

  .proj-title a:hover { color: #60a5fa; }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  /* Tech tags (green) */
  .tech {
    font-size: 0.68rem;
    background: #042214;
    border: 1px solid #15803d;
    border-radius: 4px;
    padding: 0.1rem 0.45rem;
    color: #4ade80;
  }

  /* Skills */
  .skill-group { margin-bottom: 1.5rem; }

  .skill-category {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #4b5563;
    margin-bottom: 0.55rem;
  }

  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill {
    font-size: 0.8rem;
    background: #0d1a0d;
    border: 1px solid #14532d;
    border-radius: 6px;
    padding: 0.25rem 0.65rem;
    color: #d1d5db;
  }

  /* Achievements */
  .ach-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    background: #0a0a0a;
    border: 1px solid #1e1e1e;
    border-radius: 8px;
    margin-bottom: 0.6rem;
    transition: border-color 0.15s;
  }

  .ach-row:hover { border-color: #2d2d2d; }

  .ach-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .ach-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #f9fafb;
  }

  .ach-issuer {
    font-size: 0.78rem;
    color: #6b7280;
  }
</style>

---
const title = "Chris Manlove | High-Performance C++ Systems Engineer";
const description =
  "Chris Manlove is a high-performance C++ systems engineer specializing in low-level computing efficiency, systems programming, and high-throughput network design.";
const url = "https://chrismanlove.com";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Chris Manlove",
  alternateName: ["Christopher Manlove", "DrChrisHax", "Christopher Charles Manlove"],
  url,
  email: "cmanlove1234@outlook.com",
  jobTitle: "High-Performance C++ Systems Engineer",
  description,
  alumniOf: [
    {
      "@type": "CollegeOrUniversity",
      name: "California State University, Fullerton",
      address: { "@type": "PostalAddress", addressLocality: "Fullerton", addressRegion: "CA" },
    },
    {
      "@type": "CollegeOrUniversity",
      name: "Orange Coast College",
      address: { "@type": "PostalAddress", addressLocality: "Costa Mesa", addressRegion: "CA" },
    },
  ],
  knowsAbout: [
    "C++", "C++20", "C++23",
    "Software Engineering", "Data Structures", "Algorithms",
    "Computer Architecture", "Operating Systems",
    "Computer Networking", "Network Programming",
    "Object-Oriented Programming", "Computer Science", "Compilers",
    "Backend Engineering", "Low Latency", "Concurrency", "Multithreading",
    "Lock-Free Programming", "Cache Lines", "Memory Management", "NUMA",
    "Performance Optimization", "Cryptography",
    "Quant", "High Frequency Trading", "Kernel Bypass",
  ],
  sameAs: [
    "https://www.linkedin.com/in/chris-manlove-b26b31209/",
    "https://github.com/DrChrisHax",
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Chris Manlove" />
    <meta name="keywords" content="Chris Manlove, Christopher Manlove, C++, C++20, C++23, Software Engineer, Data Structures, Algorithms, Computer Architecture, Operating Systems, Computer Networking, Network Programming, Object-Oriented Programming, Computer Science, Compilers, Backend Engineering, Low Latency, Concurrency, Multithreading, Lock-Free Programming, Cache Lines, Memory Management, NUMA, Performance Optimization, Cryptography, Quant, High Frequency Trading, Kernel Bypass" />
    <meta name="robots" content="index, follow" />
    <meta name="google-site-verification" content="tpjh_vr_KbK4cKP3c1Ix4_TYxXtyOdMgOcaB_fVCgW4" />
    <link rel="canonical" href={url} />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Chris Manlove" />
    <meta property="profile:first_name" content="Chris" />
    <meta property="profile:last_name" content="Manlove" />
    <meta property="profile:username" content="DrChrisHax" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background-color: #000;
        color: #fff;
        font-family: system-ui, -apple-system, sans-serif;
        line-height: 1.6;
        padding: 3rem 1.5rem;
        max-width: 800px;
        margin: 0 auto;
      }

      h1 { font-size: 2.5rem; font-weight: 700; letter-spacing: -0.5px; }
      h2 { font-size: 1.1rem; font-weight: 400; color: #aaa; margin-top: 0.4rem; margin-bottom: 2rem; }
      h3 { font-size: 1rem; font-weight: 600; color: #ccc; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px; }

      p { color: #ccc; margin-bottom: 1.5rem; }

      section { margin-bottom: 2.5rem; }

      .skills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .skill {
        background: #111;
        border: 1px solid #333;
        padding: 0.25rem 0.75rem;
        border-radius: 999px;
        font-size: 0.875rem;
        color: #ccc;
      }

      .projects { display: flex; flex-direction: column; gap: 1rem; }

      .project {
        border: 1px solid #222;
        border-radius: 8px;
        padding: 1rem 1.25rem;
      }

      .project-title { font-weight: 600; margin-bottom: 0.25rem; }
      .project-desc { font-size: 0.9rem; color: #aaa; margin: 0; }

      a { color: #7eb8f7; text-decoration: none; }
      a:hover { text-decoration: underline; }

      .links { display: flex; gap: 1.5rem; }
    </style>
  </head>
  <body>
    <header>
      <h1>Chris Manlove</h1>
      <h2>High-Performance C++ Systems Engineer</h2>
    </header>

    <main>
      <section>
        <p>
          Chris Manlove (Christopher Manlove) is a C++ systems engineer focused on low-latency
          networking, high-frequency trading infrastructure, performance optimization, and
          post-quantum cryptography. Currently a C++ Development Intern at ScalpTrade rewriting
          a market-data processing service in C++20, and holding a B.S. in Computer Science
          (3.75 GPA) from California State University, Fullerton (May 2026).
        </p>
      </section>

      <section>
        <h3>Core Expertise</h3>
        <div class="skills">
          <span class="skill">C++17 / 20 / 23</span>
          <span class="skill">Data Structures</span>
          <span class="skill">Algorithms</span>
          <span class="skill">Operating Systems</span>
          <span class="skill">Concurrency</span>
          <span class="skill">Linux</span>
          <span class="skill">GCC</span>
        </div>
      </section>

      <section>
        <h3>Featured Projects</h3>
        <div class="projects">
          <div class="project">
            <div class="project-title">
              <a href="https://github.com/DrChrisHax/PostQuantumVPN" rel="noopener noreferrer">
                Quantum Edge: Post-Quantum VPN
              </a>
            </div>
            <p class="project-desc">
              C++23 VPN with a hybrid ML-KEM + X25519 handshake, epoll event loop, and throughput competitive with WireGuard. 
              Uses ChaCha20-Poly1305, BLAKE3, and HKDF via OpenSSL.
            </p>
          </div>
          <div class="project">
            <div class="project-title">
              <a href="https://github.com/DrChrisHax/Proxy_Server" rel="noopener noreferrer">
                SOCKS4 Proxy Server
              </a>
            </div>
            <p class="project-desc">
              An epoll-based event loop supporting 100,000+ concurrent connections. 
              Implements a custom LRU cache, DNS resolution, and SHA-256 with zero third-party dependencies.
            </p>
          </div>
        </div>
      </section>

      <section>
        <h3>Links</h3>
        <nav class="links" aria-label="External profiles">
          <a href="https://github.com/DrChrisHax" rel="noopener noreferrer">GitHub</a>
          <a href="https://www.linkedin.com/in/chris-manlove-b26b31209/" rel="noopener noreferrer">LinkedIn</a>
          <a href="mailto:cmanlove1234@outlook.com">Email</a>
        </nav>
      </section>
    </main>
  </body>
</html>
